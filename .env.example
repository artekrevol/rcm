# ─────────────────────────────────────────────────────────────────────────────
# ClaimShield Health — Environment Variables Reference
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Stedi EDI Clearinghouse ───────────────────────────────────────────────────
# Stedi uses ONE API key for all environments. Production vs test separation
# is controlled ONLY by ISA15 inside the 837P EDI envelope:
#   ISA15='T' → Stedi validates, returns 277CA, does NOT forward to the real payer
#   ISA15='P' → Stedi validates, returns 277CA, AND forwards to the real payer
#
# STEDI_API_KEY: Your Stedi API key (required for all EDI features)
STEDI_API_KEY=

# STEDI_ENV: Controls the default ISA15 indicator for this deployment.
#   - "test"       → ISA15=T by default (safe for development, staging, QA)
#   - "production" → ISA15=P by default (live payer submissions)
#
# Omit or set to anything other than "production" to default to test mode.
# Only set to "production" in your Railway/production deployment.
STEDI_ENV=test

# STEDI_WEBHOOK_SECRET: Secret for validating Stedi webhook POSTs.
STEDI_WEBHOOK_SECRET=

# STEDI_AUTOMATED_TEST_MODE: Set to "true" ONLY for automated E2E pipelines
# that need to call Stedi. Automated agents can only submit ISA15=T claims;
# any ISA15=P attempt is blocked with AutomatedSubmissionBlocked.
# Default: unset (automated submissions fully blocked).
STEDI_AUTOMATED_TEST_MODE=

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/claimshield

# ── Authentication ────────────────────────────────────────────────────────────
SESSION_SECRET=change-this-to-a-long-random-string

# ── Twilio (SMS outreach) ─────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_MESSAGING_SERVICE_SID=

# ── Gmail (email outreach) ───────────────────────────────────────────────────
GMAIL_USER=
GMAIL_APP_PASSWORD=

# ── VAPI (AI voice agent) ────────────────────────────────────────────────────
VAPI_API_KEY=
VAPI_PUBLIC_KEY=

# ── VerifyTX (insurance verification) ────────────────────────────────────────
VERIFYTX_CLIENT_ID=
VERIFYTX_CLIENT_SECRET=
VERIFYTX_USERNAME=
VERIFYTX_PASSWORD=
